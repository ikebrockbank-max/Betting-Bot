# ── PrizePicks Scanner Config ─────────────────────────────────────
# How often to scan (minutes). 15 is recommended.
SCAN_INTERVAL_MIN=15

# ── Email alerts via Resend (resend.com — free 3k emails/month) ───
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
NOTIFY_EMAIL=you@gmail.com
# Use onboarding@resend.dev for testing, or your own verified domain:
NOTIFY_FROM=alerts@yourdomain.com

# ── SMS alerts via Twilio (twilio.com — ~$0.01/text) ─────────────
# Leave blank to disable SMS
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_FROM_NUMBER=+15551234567
NOTIFY_PHONE=+15559876543

# ── Kalshi API (for the edge scanner) ────────────────────────────
KALSHI_API_KEY_ID=
ODDS_API_KEY=
